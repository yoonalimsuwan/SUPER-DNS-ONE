# 2. Advanced Flux Splitting (AUSM+ and HLLC) with MUSCL Reconstruction
# =============================================================================
class FluxSplitter:
    """
    Computes inviscid convective fluxes using Riemann solvers.
    Supports AUSM+ and HLLC, with optional MUSCL reconstruction.
    """
    def __init__(self, gamma=1.4, method='ausm', muscl=False, kappa=1.0/3.0):
        self.gamma = gamma
        self.method = method.lower()  # 'ausm' or 'hllc'
        self.muscl = muscl
        self.kappa = kappa
        self.eps = 1e-8

    def _reconstruct(self, q, axis):
        """
        Return left and right states at cell interfaces.
        Uses the padded array q (size N+2) and returns
        states for all interfaces: qL = q[i], qR = q[i+1]
        Output shape: (nx+1, ny, nz) for axis=0 etc.
        """
        if not self.muscl:
            # Without reconstruction, left = cell i, right = cell i+1
            if axis == 0:
                qL = q[:-1, 1:-1, 1:-1]
                qR = q[1:, 1:-1, 1:-1]
            elif axis == 1:
                qL = q[1:-1, :-1, 1:-1]
                qR = q[1:-1, 1:, 1:-1]
            else:
                qL = q[1:-1, 1:-1, :-1]
                qR = q[1:-1, 1:-1, 1:]
            return qL, qR

        # MUSCL reconstruction with minmod limiter
        def minmod(a, b):
            return torch.where(a*b > 0, torch.where(torch.abs(a) < torch.abs(b), a, b), torch.zeros_like(a))

        if axis == 0:
            # interior cells: 1 .. nx (indices 1:-1 in padded)
            q_im1 = q[:-3, 1:-1, 1:-1]
            qi    = q[1:-2, 1:-1, 1:-1]
            qip1  = q[2:-1, 1:-1, 1:-1]
            qip2  = q[3:, 1:-1, 1:-1]
            dL = qip1 - qi
            dR = qi - q_im1
            dC = (qip1 - q_im1) * 0.5
            slope_i = minmod(self.kappa * dL, dC)
            dL1 = qip2 - qip1
            dR1 = qip1 - qi
            dC1 = (qip2 - qi) * 0.5
            slope_ip1 = minmod(self.kappa * dL1, dC1)
            qL_int = qi + 0.5 * slope_i
            qR_int = qip1 - 0.5 * slope_ip1

            qL_full = torch.zeros(q.shape[0]-1, q.shape[1]-2, q.shape[2]-2, device=q.device)
            qR_full = torch.zeros_like(qL_full)
            qL_full[1:-1] = qL_int
            qR_full[1:-1] = qR_int
            # first‑order boundaries
            qL_full[0] = q[0, 1:-1, 1:-1]
            qR_full[0] = q[1, 1:-1, 1:-1]
            qL_full[-1] = q[-2, 1:-1, 1:-1]
            qR_full[-1] = q[-1, 1:-1, 1:-1]
            return qL_full, qR_full
        elif axis == 1:
            q_im1 = q[1:-1, :-3, 1:-1]
            qi    = q[1:-1, 1:-2, 1:-1]
            qip1  = q[1:-1, 2:-1, 1:-1]
            qip2  = q[1:-1, 3:, 1:-1]
            dL = qip1 - qi
            dR = qi - q_im1
            dC = (qip1 - q_im1) * 0.5
            slope_i = minmod(self.kappa * dL, dC)
            dL1 = qip2 - qip1
            dR1 = qip1 - qi
            dC1 = (qip2 - qi) * 0.5
            slope_ip1 = minmod(self.kappa * dL1, dC1)
            qL_int = qi + 0.5 * slope_i
            qR_int = qip1 - 0.5 * slope_ip1

            qL_full = torch.zeros(q.shape[0]-2, q.shape[1]-1, q.shape[2]-2, device=q.device)
            qR_full = torch.zeros_like(qL_full)
            qL_full[:, 1:-1] = qL_int
            qR_full[:, 1:-1] = qR_int
            qL_full[:, 0] = q[1:-1, 0, 1:-1]
            qR_full[:, 0] = q[1:-1, 1, 1:-1]
            qL_full[:, -1] = q[1:-1, -2, 1:-1]
            qR_full[:, -1] = q[1:-1, -1, 1:-1]
            return qL_full, qR_full
        else:
            q_im1 = q[1:-1, 1:-1, :-3]
            qi    = q[1:-1, 1:-1, 1:-2]
            qip1  = q[1:-1, 1:-1, 2:-1]
            qip2  = q[1:-1, 1:-1, 3:]
            dL = qip1 - qi
            dR = qi - q_im1
            dC = (qip1 - q_im1) * 0.5
            slope_i = minmod(self.kappa * dL, dC)
            dL1 = qip2 - qip1
            dR1 = qip1 - qi
            dC1 = (qip2 - qi) * 0.5
            slope_ip1 = minmod(self.kappa * dL1, dC1)
            qL_int = qi + 0.5 * slope_i
            qR_int = qip1 - 0.5 * slope_ip1

            qL_full = torch.zeros(q.shape[0]-2, q.shape[1]-2, q.shape[2]-1, device=q.device)
            qR_full = torch.zeros_like(qL_full)
            qL_full[..., 1:-1] = qL_int
            qR_full[..., 1:-1] = qR_int
            qL_full[..., 0] = q[1:-1, 1:-1, 0]
            qR_full[..., 0] = q[1:-1, 1:-1, 1]
            qL_full[..., -1] = q[1:-1, 1:-1, -2]
            qR_full[..., -1] = q[1:-1, 1:-1, -1]
            return qL_full, qR_full

    def _ausm_flux(self, rhoL, uL, vL, wL, pL, rhoR, uR, vR, wR, pR, normal):
        cL = torch.sqrt(self.gamma * pL / (rhoL + self.eps))
        cR = torch.sqrt(self.gamma * pR / (rhoR + self.eps))
        if normal == 0:
            unL = uL; unR = uR
        elif normal == 1:
            unL = vL; unR = vR
        else:
            unL = wL; unR = wR
        ML = unL / (cL + self.eps)
        MR = unR / (cR + self.eps)
        c_face = 0.5 * (cL + cR)
        M_plus = 0.25 * (ML + 1.0)**2
        M_minus = -0.25 * (MR - 1.0)**2
        M_face = M_plus + M_minus
        p_plus = 0.25 * pL * (ML + 1.0)**2 * (2.0 - ML)
        p_minus = 0.25 * pR * (MR - 1.0)**2 * (2.0 + MR)
        p_face = p_plus + p_minus

        if M_face >= 0:
            rho_face = rhoL; un_face = unL
            if normal == 0: vu = vL; wu = wL
            elif normal == 1: vu = uL; wu = wL
            else: vu = uL; wu = vL
        else:
            rho_face = rhoR; un_face = unR
            if normal == 0: vu = vR; wu = wR
            elif normal == 1: vu = uR; wu = wR
            else: vu = uR; wu = vR

        mass_flux = M_face * c_face * rho_face
        F_rho = mass_flux
        if normal == 0:
            F_rhou = mass_flux * un_face + p_face
            F_rhov = mass_flux * vu
            F_rhow = mass_flux * wu
        elif normal == 1:
            F_rhou = mass_flux * vu
            F_rhov = mass_flux * un_face + p_face
            F_rhow = mass_flux * wu
        else:
            F_rhou = mass_flux * vu
            F_rhov = mass_flux * wu
            F_rhow = mass_flux * un_face + p_face

        # total enthalpy H = (E+p)/rho  (use p_face consistently)
        E_face = p_face/(self.gamma-1.0) + 0.5*rho_face*(un_face**2 + vu**2 + wu**2)
        H_face = (E_face + p_face) / (rho_face + self.eps)
        F_rhoE = mass_flux * H_face
        return F_rho, F_rhou, F_rhov, F_rhow, F_rhoE

    def _hllc_flux(self, rhoL, uL, vL, wL, pL, rhoR, uR, vR, wR, pR, normal):
        cL = torch.sqrt(self.gamma * pL / (rhoL + self.eps))
        cR = torch.sqrt(self.gamma * pR / (rhoR + self.eps))
        if normal == 0:
            unL = uL; unR = uR; utL = vL; utR = vR; uwL = wL; uwR = wR
        elif normal == 1:
            unL = vL; unR = vR; utL = uL; utR = uR; uwL = wL; uwR = wR
        else:
            unL = wL; unR = wR; utL = uL; utR = uR; uwL = vL; uwR = vR

        R = torch.sqrt(rhoR / (rhoL + self.eps))
        un_roe = (unL + R*unR) / (1.0 + R)
        c_roe = (cL + R*cR) / (1.0 + R)
        SL = torch.min(unL - cL, un_roe - c_roe)
        SR = torch.max(unR + cR, un_roe + c_roe)
        # Wave speed estimates
        S_star = (pR - pL + rhoL*unL*(SL-unL) - rhoR*unR*(SR-unR)) / (rhoL*(SL-unL) - rhoR*(SR-unR) + self.eps)

        mask_L = SL >= 0
        mask_R = SR <= 0
        mask_star = ~(mask_L | mask_R)

        rho_face = torch.zeros_like(rhoL)
        un_face = torch.zeros_like(rhoL)
        p_face = torch.zeros_like(rhoL)
        ut_face = torch.zeros_like(rhoL)
        uw_face = torch.zeros_like(rhoL)
        E_face = torch.zeros_like(rhoL)

        # Left state
        rho_face[mask_L] = rhoL[mask_L]
        un_face[mask_L] = unL[mask_L]
        p_face[mask_L] = pL[mask_L]
        ut_face[mask_L] = utL[mask_L]
        uw_face[mask_L] = uwL[mask_L]
        E_face[mask_L] = pL[mask_L]/(self.gamma-1.0) + 0.5*rhoL[mask_L]*(unL[mask_L]**2+utL[mask_L]**2+uwL[mask_L]**2)

        # Right state
        rho_face[mask_R] = rhoR[mask_R]
        un_face[mask_R] = unR[mask_R]
        p_face[mask_R] = pR[mask_R]
        ut_face[mask_R] = utR[mask_R]
        uw_face[mask_R] = uwR[mask_R]
        E_face[mask_R] = pR[mask_R]/(self.gamma-1.0) + 0.5*rhoR[mask_R]*(unR[mask_R]**2+utR[mask_R]**2+uwR[mask_R]**2)

        # Star state (correct left and right branches)
        if mask_star.any():
            rhoL_s = rhoL[mask_star]; unL_s = unL[mask_star]; SL_s = SL[mask_star]; S_star_s = S_star[mask_star]
            pL_s = pL[mask_star]; utL_s = utL[mask_star]; uwL_s = uwL[mask_star]
            rhoR_s = rhoR[mask_star]; unR_s = unR[mask_star]; SR_s = SR[mask_star]
            pR_s = pR[mask_star]; utR_s = utR[mask_star]; uwR_s = uwR[mask_star]

            # Left star
            factorL = (SL_s - unL_s) / (SL_s - S_star_s + self.eps)
            rho_starL = rhoL_s * factorL
            E_starL = (pL_s/(self.gamma-1.0) + 0.5*rhoL_s*(unL_s**2+utL_s**2+uwL_s**2)) * factorL
            p_starL = pL_s + rhoL_s * (unL_s - SL_s) * (unL_s - S_star_s)
            # Right star
            factorR = (SR_s - unR_s) / (SR_s - S_star_s + self.eps)
            rho_starR = rhoR_s * factorR
            E_starR = (pR_s/(self.gamma-1.0) + 0.5*rhoR_s*(unR_s**2+utR_s**2+uwR_s**2)) * factorR
            p_starR = pR_s + rhoR_s * (unR_s - SR_s) * (unR_s - S_star_s)

            rho_face[mask_star] = torch.where(S_star_s >= 0, rho_starL, rho_starR)
            un_face[mask_star] = S_star_s
            p_face[mask_star] = torch.where(S_star_s >= 0, p_starL, p_starR)
            ut_face[mask_star] = torch.where(S_star_s >= 0, utL_s, utR_s)
            uw_face[mask_star] = torch.where(S_star_s >= 0, uwL_s, uwR_s)
            E_face[mask_star] = torch.where(S_star_s >= 0, E_starL, E_starR)

        # Flux computation
        mass_flux = rho_face * un_face
        F_rho = mass_flux
        if normal == 0:
            F_rhou = mass_flux * un_face + p_face
            F_rhov = mass_flux * ut_face
            F_rhow = mass_flux * uw_face
        elif normal == 1:
            F_rhou = mass_flux * ut_face
            F_rhov = mass_flux * un_face + p_face
            F_rhow = mass_flux * uw_face
        else:
            F_rhou = mass_flux * ut_face
            F_rhov = mass_flux * uw_face
            F_rhow = mass_flux * un_face + p_face

        H_face = (E_face + p_face) / (rho_face + self.eps)
        F_rhoE = mass_flux * H_face
        return F_rho, F_rhou, F_rhov, F_rhow, F_rhoE

    def compute_flux_divergence(self, rho_pad, u_pad, v_pad, w_pad, p_pad, dx):
        """
        Returns divergence of convective fluxes for interior cells (nx, ny, nz).
        """
        nx, ny, nz = rho_pad.shape[0]-2, rho_pad.shape[1]-2, rho_pad.shape[2]-2
        div_flux = torch.zeros(nx, ny, nz, 5, device=rho_pad.device)

        for axis in range(3):
            rhoL, rhoR = self._reconstruct(rho_pad, axis)
            uL, uR = self._reconstruct(u_pad, axis)
            vL, vR = self._reconstruct(v_pad, axis)
            wL, wR = self._reconstruct(w_pad, axis)
            pL, pR = self._reconstruct(p_pad, axis)

            if self.method == 'ausm':
                flux_fn = self._ausm_flux
            else:
                flux_fn = self._hllc_flux

            F_rho, F_u, F_v, F_w, F_E = flux_fn(rhoL, uL, vL, wL, pL,
                                                  rhoR, uR, vR, wR, pR, axis)

            if axis == 0:
                # F_* shape: (nx+1, ny, nz)
                dF_rho = (F_rho[1:] - F_rho[:-1]) / dx
                div_flux[..., 0] += dF_rho
                div_flux[..., 1] += (F_u[1:] - F_u[:-1]) / dx
                div_flux[..., 2] += (F_v[1:] - F_v[:-1]) / dx
                div_flux[..., 3] += (F_w[1:] - F_w[:-1]) / dx
                div_flux[..., 4] += (F_E[1:] - F_E[:-1]) / dx
            elif axis == 1:
                # F_* shape: (nx, ny+1, nz)
                dF_rho = (F_rho[:, 1:] - F_rho[:, :-1]) / dx
                div_flux[..., 0] += dF_rho
                div_flux[..., 1] += (F_u[:, 1:] - F_u[:, :-1]) / dx
                div_flux[..., 2] += (F_v[:, 1:] - F_v[:, :-1]) / dx
                div_flux[..., 3] += (F_w[:, 1:] - F_w[:, :-1]) / dx
                div_flux[..., 4] += (F_E[:, 1:] - F_E[:, :-1]) / dx
            else:
                # F_* shape: (nx, ny, nz+1)
                dF_rho = (F_rho[..., 1:] - F_rho[..., :-1]) / dx
                div_flux[..., 0] += dF_rho
                div_flux[..., 1] += (F_u[..., 1:] - F_u[..., :-1]) / dx
                div_flux[..., 2] += (F_v[..., 1:] - F_v[..., :-1]) / dx
                div_flux[..., 3] += (F_w[..., 1:] - F_w[..., :-1]) / dx
                div_flux[..., 4] += (F_E[..., 1:] - F_E[..., :-1]) / dx
        return div_flux

